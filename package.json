{
  "private": true,
  "scripts": {
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:restart": "npm run docker:down && npm run docker:up",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "dev": "graphql-codegen --config codegen.ts && node ./add-ts-nocheck.js && next dev --webpack",
    "build": "graphql-codegen --config codegen.ts && node ./add-ts-nocheck.js && next build",
    "docker:build": "next build",
    "start": "next start",
    "lint": "next lint",
    "codegen": "graphql-codegen --config codegen.ts && node ./add-ts-nocheck.js",
    "find-deadcode": "ts-prune",
    "knip": "knip"
  },
  "dependencies": {
    "@iminside/react-yandex-maps": "^1.2.7",
    "clsx": "^2.1.1",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "next": "^16",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-masonry-css": "^1.0.16",
    "yet-another-react-lightbox": "^3.31.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "5.3.0",
    "@graphql-codegen/schema-ast": "^5.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "knip": "^6.4.1",
    "nanoid": "^5.1.9",
    "next-devtools-mcp": "^0.3.10",
    "sass": "^1.99.0",
    "typescript": "^6.0.3"
  }
}
