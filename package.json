{
	"private": true,
	"scripts": {
		"docker:up": "docker compose up -d --build",
		"docker:down": "docker compose down",
		"docker:restart": "npm run docker:down && npm run docker:up",
		"docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
		"docker:prod:down": "docker compose -f docker-compose.prod.yml down",
		"docker:prod-test": "docker compose -f docker-compose.test-prod.yml up --build",
		"docker:prod-test:down": "docker compose -f docker-compose.test-prod.yml down",
		"dev": "graphql-codegen --config codegen.ts && node ./add-ts-nocheck.js && next dev --webpack",
		"build": "graphql-codegen --config codegen.ts && node ./add-ts-nocheck.js && next build",
		"docker:build": "next build",
		"start": "next start",
		"lint": "next lint",
		"codegen": "graphql-codegen --config codegen.ts && node ./add-ts-nocheck.js",
		"knip": "knip",
		"format": "biome check --write .",
		"update-deps": "npx -y npm-check-updates -u && npm install",
		"postinstall": "lefthook install"
	},
	"dependencies": {
		"@iminside/react-yandex-maps": "^1.2.7",
		"clsx": "^2.1.1",
		"graphql": "^16.14.0",
		"graphql-request": "^7.4.0",
		"next": "^16",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@graphql-codegen/cli": "^7.0.0",
		"@graphql-codegen/client-preset": "6.0.0",
		"@graphql-codegen/schema-ast": "^6.0.0",
		"@next/env": "^16.2.6",
		"@types/node": "^25.7.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"knip": "^6.13.1",
		"lefthook": "^2.1.6",
		"nanoid": "^5.1.11",
		"sass": "^1.99.0",
		"typescript": "^6.0.3"
	}
}
